# -*- coding: utf-8 -*-
"""
Force Subscribe Telegram Bot
------------------------------------------------
এই বটটি ব্যবহারকারীকে আপনার নির্দিষ্ট ৪টি চ্যানেলে জয়েন করতে বাধ্য করবে।
জয়েন না করলে সে আপনার বট/অ্যাপের কোনো ফিচার (যেমন পোল ভোট, /start ইত্যাদি)
ব্যবহার করতে পারবে না।

প্রয়োজনীয় লাইব্রেরি:
    pip install python-telegram-bot==21.6

গুরুত্বপূর্ণ শর্ত (অবশ্যই মানতে হবে):
    1. আপনার বটকে অবশ্যই ৪টি চ্যানেলেই "Admin" বানাতে হবে
       (কমপক্ষে "Add members" / "Invite users via link" পারমিশন লাগবে
        মেম্বারশিপ চেক করার জন্য)।
    2. চ্যানেলগুলো public হলে username দিয়ে কাজ করবে (@channel_username)।
       Private চ্যানেল হলে chat_id (যেমন -100xxxxxxxxxx) ব্যবহার করতে হবে।
"""

import os
import logging
from telegram import (
    Update,
    InlineKeyboardButton,
    InlineKeyboardMarkup,
)
from telegram.ext import (
    ApplicationBuilder,
    CommandHandler,
    CallbackQueryHandler,
    ContextTypes,
    PollAnswerHandler,
    ChatMemberHandler,
)
from telegram.constants import ChatMemberStatus

logging.basicConfig(
    format="%(asctime)s - %(name)s - %(levelname)s - %(message)s",
    level=logging.INFO,
)
logger = logging.getLogger(__name__)

# ================== কনফিগারেশন (এখানে আপনার মান বসান) ==================

BOT_TOKEN = os.environ.get("BOT_TOKEN", "YOUR_BOT_TOKEN_HERE")  # @BotFather থেকে পাওয়া টোকেন

# আপনার ৪টি চ্যানেল (public username আকারে @ সহ লিখুন)
REQUIRED_CHANNELS = [
    {"id": "@sifatearningboarawwuhdjdb", "name": "Sifat Earning Bd", "url": "https://t.me/sifatearningboarawwuhdjdb"},
    {"id": "@mdsksifatkhan",            "name": "MD SK Sifat Khan", "url": "https://t.me/mdsksifatkhan"},
    {"id": "@sifatmiys420A",            "name": "Sifat Miys",       "url": "https://t.me/sifatmiys420A"},
    {"id": "@QuickEarnBDBot420A",       "name": "Quick Earn BD",    "url": "https://t.me/QuickEarnBDBot420A"},
]

# ==========================================================================


async def is_member_of_all_channels(user_id: int, context: ContextTypes.DEFAULT_TYPE) -> list:
    """
    যেসব চ্যানেলে ইউজার জয়েন করেনি সেগুলোর লিস্ট রিটার্ন করে।
    খালি লিস্ট মানে ইউজার সব চ্যানেলে জয়েন করা আছে।
    """
    not_joined = []
    for channel in REQUIRED_CHANNELS:
        try:
            member = await context.bot.get_chat_member(
                chat_id=channel["id"], user_id=user_id
            )
            if member.status in (
                ChatMemberStatus.LEFT,
                ChatMemberStatus.BANNED,
            ):
                not_joined.append(channel)
        except Exception as e:
            # বট চ্যানেলে অ্যাডমিন না থাকলে বা চ্যানেল আইডি ভুল হলে এখানে error আসবে
            logger.warning(f"Membership check failed for {channel['id']}: {e}")
            not_joined.append(channel)
    return not_joined


def build_join_keyboard(missing_channels: list) -> InlineKeyboardMarkup:
    buttons = [
        [InlineKeyboardButton(f"➕ Join {ch['name']}", url=ch["url"])]
        for ch in missing_channels
    ]
    buttons.append(
        [InlineKeyboardButton("✅ আমি জয়েন করেছি, আবার চেক করুন", callback_data="check_join")]
    )
    return InlineKeyboardMarkup(buttons)


async def start(update: Update, context: ContextTypes.DEFAULT_TYPE):
    user_id = update.effective_user.id
    missing = await is_member_of_all_channels(user_id, context)

    if missing:
        text = (
            "👋 স্বাগতম!\n\n"
            "❗ এই অ্যাপ/বট ব্যবহার করতে হলে আপনাকে অবশ্যই নিচের সবগুলো "
            "চ্যানেলে জয়েন করতে হবে:"
        )
        await update.message.reply_text(
            text, reply_markup=build_join_keyboard(missing)
        )
        return

    await update.message.reply_text(
        "✅ আপনি সব চ্যানেলে জয়েন করা আছেন। এখন আপনি বটের সব ফিচার ব্যবহার করতে পারবেন!"
    )


async def check_join_callback(update: Update, context: ContextTypes.DEFAULT_TYPE):
    query = update.callback_query
    user_id = query.from_user.id
    missing = await is_member_of_all_channels(user_id, context)

    if missing:
        await query.answer("❌ আপনি এখনো সবগুলো চ্যানেলে জয়েন করেননি!", show_alert=True)
        await query.edit_message_reply_markup(reply_markup=build_join_keyboard(missing))
    else:
        await query.answer("✅ ধন্যবাদ! আপনি এখন সব ফিচার ব্যবহার করতে পারবেন।", show_alert=True)
        await query.edit_message_text("✅ আপনি সব চ্যানেলে জয়েন করা আছেন। এখন বট ব্যবহার করুন।")


async def poll_answer_handler(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """
    কেউ যখন পোলে ভোট দেয়, সেটা চেক করে সে চ্যানেলগুলোতে জয়েন করা কিনা।
    জয়েন না থাকলে তার ভোট বাতিল বলে গণ্য করে তাকে মেসেজ পাঠানো হয়।

    বিঃদ্রঃ টেলিগ্রাম বট API দিয়ে সরাসরি কারো ভোট "মুছে ফেলা" যায় না,
    কিন্তু আপনি তাকে সতর্ক করতে পারেন এবং নিজের সিস্টেমে (ডাটাবেজে) সেই ভোট
    গণনা থেকে বাদ দিতে পারেন — অর্থাৎ ফলাফল ক্যালকুলেশনের সময় শুধু যারা
    জয়েন করা তাদের ভোটই ধরবেন।
    """
    poll_answer = update.poll_answer
    user_id = poll_answer.user.id

    missing = await is_member_of_all_channels(user_id, context)
    if missing:
        try:
            await context.bot.send_message(
                chat_id=user_id,
                text=(
                    "⚠️ আপনার ভোট গণনা করা হবে না কারণ আপনি এখনো নিচের "
                    "চ্যানেলগুলোতে জয়েন করেননি:"
                ),
                reply_markup=build_join_keyboard(missing),
            )
        except Exception as e:
            # ইউজার বটকে ব্লক করে রাখলে বা প্রাইভেট মেসেজ বন্ধ থাকলে এখানে error আসবে
            logger.warning(f"Could not DM user {user_id}: {e}")
        # এখানে আপনি নিজের ডাটাবেজে এই user_id-কে "invalid_vote" হিসেবে সেভ করে
        # রাখতে পারেন, যাতে ফাইনাল রেজাল্ট গণনার সময় তার ভোট বাদ দেওয়া যায়।
    else:
        logger.info(f"Valid vote counted from user {user_id}")
        # এখানে আপনি ভ্যালিড ভোট নিজের ডাটাবেজে সেভ করতে পারেন।


def main():
    app = ApplicationBuilder().token(BOT_TOKEN).build()

    app.add_handler(CommandHandler("start", start))
    app.add_handler(CallbackQueryHandler(check_join_callback, pattern="^check_join$"))
    app.add_handler(PollAnswerHandler(poll_answer_handler))

    logger.info("Bot চালু হয়েছে...")
    app.run_polling(allowed_updates=Update.ALL_TYPES)


if __name__ == "__main__":
    main()
